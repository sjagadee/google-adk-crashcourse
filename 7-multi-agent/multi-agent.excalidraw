    {
      "id": "_Yh2EjRoQSynqPDaDXd0O",
      "type": "text",
      "x": 967.5380164849416,
      "y": 128.8305468366455,
      "width": 616.59912109375,
      "height": 162,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffd8a8",
