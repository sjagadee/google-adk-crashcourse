      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "at",
      "roundness": null,
      "seed": 1708314407,
      "version": 668,
      "versionNonce": 953274217,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778427115263,
      "link": null,
      "locked": false,
      "text": "Here ADK would like to reply as soon as possible to the agents,\nThe root agent here would try to find the best possible sub-agent,\nthe can answer the user query and delegate the work to it.\n- One delegation to get the answer\n- Loops will not be used in simple multi-agent structure like this one\n",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Here ADK would like to reply as soon as possible to the agents,\nThe root agent here would try to find the best possible sub-agent,\nthe can answer the user query and delegate the work to it.\n- One delegation to get the answer\n- Loops will not be used in simple multi-agent structure like this one\n",
      "autoResize": true,
      "lineHeight": 1.35
    }
